}

// Bot服务 Model
type (
	// CreateBot
	CreateBotReq {
		Name        string `json:"name"`
		Description string `json:"description,optional"`
		Avatar      string `json:"avatar,optional"`
		WebhookUrl  string `json:"webhook_url,optional"`
		HomepageUrl string `json:"homepage_url,optional"`
		PrivacyUrl  string `json:"privacy_url,optional"`
	}
	CreateBotResp {
		BotId        string `json:"bot_id"`
		ClientId     string `json:"client_id"`
		ClientSecret string `json:"client_secret"`
	}
	// ListMyBots
	ListMyBotsReq {
		Page int `form:"page,default=1"`
		Size int `form:"size,default=20"`
	}
	BotItem {
		BotId        string `json:"bot_id"`
		Name         string `json:"name"`
		Description  string `json:"description"`
		Avatar       string `json:"avatar"`
		Status       string `json:"status"`
		ClientId     string `json:"client_id"`
		InstalledCnt int64  `json:"installed_cnt"`
		CreatedAt    int64  `json:"created_at"`
		UpdatedAt    int64  `json:"updated_at"`
	}
	ListMyBotsResp {
		List  []BotItem `json:"list"`
		Total int64     `json:"total"`
	}
	// ListCommunityBots
	ListCommunityBotsReq {
		Keyword string `form:"keyword,optional"`
	}
	ListCommunityBotsResp {
		List []BotItem `json:"list"`
	}
	// GetBot
	GetBotReq {
		BotId string `path:"bot_id"`
	}
	GetBotResp {
		BotId       string `json:"bot_id"`
		Name        string `json:"name"`
		Description string `json:"description"`
		Avatar      string `json:"avatar"`
		Status      string `json:"status"`
		ClientId    string `json:"client_id"`
		WebhookUrl  string `json:"webhook_url"`
		HomepageUrl string `json:"homepage_url"`
		PrivacyUrl  string `json:"privacy_url"`
		CreatedAt   int64  `json:"created_at"`
		UpdatedAt   int64  `json:"updated_at"`
	}
	// UpdateBot
	UpdateBotReq {
		BotId       string `path:"bot_id"`
		Name        string `json:"name,optional"`
		Description string `json:"description,optional"`
		Avatar      string `json:"avatar,optional"`
		WebhookUrl  string `json:"webhook_url,optional"`
		HomepageUrl string `json:"homepage_url,optional"`
		PrivacyUrl  string `json:"privacy_url,optional"`
	}
	UpdateBotResp  {}
	// DeleteBot
	DeleteBotReq {
		BotId string `path:"bot_id"`
	}
	DeleteBotResp  {}
	// GetBotInstallations
	GetBotInstallationsReq {
		BotId string `path:"bot_id"`
		Page  int    `form:"page,default=1"`
		Size  int    `form:"size,default=20"`
	}
	InstallationItem {
		InstId      int64    `json:"inst_id"`
		BotId       string   `json:"bot_id"`
		BotName     string   `json:"bot_name"`
		ConvId      string   `json:"conv_id"`
		ConvType    string   `json:"conv_type"`
		Permissions []string `json:"permissions"`
		InstalledAt int64    `json:"installed_at"`
	}
	GetBotInstallationsResp {
		List  []InstallationItem `json:"list"`
		Total int64              `json:"total"`
	}
	// GetBotRateLimit
	GetBotRateLimitReq {
		BotId string `path:"bot_id"`
	}
	GetBotRateLimitResp {
		BotId          string `json:"bot_id"`
		MaxConcurrency int32  `json:"max_concurrency"`
		MaxRequests    int64  `json:"max_requests"`
		WindowSeconds  int32  `json:"window_seconds"`
		IsCustom       bool   `json:"is_custom"`
	}
	// UpdateBotRateLimit
	UpdateBotRateLimitReq {
		BotId          string `path:"bot_id"`
		MaxConcurrency int32  `json:"max_concurrency,optional"`
		MaxRequests    int64  `json:"max_requests,optional"`
		WindowSeconds  int32  `json:"window_seconds,optional"`
	}
	UpdateBotRateLimitResp  {}
	// RegenerateCredential
	RegenerateCredentialReq {
		BotId string `path:"bot_id"`
	}
	RegenerateCredentialResp {
		ClientId     string `json:"client_id"`
		ClientSecret string `json:"client_secret"`
	}
	// RotateWebhookSecret
	RotateWebhookSecretReq {
		BotId string `path:"bot_id"`
	}
	RotateWebhookSecretResp {
		WebhookSecret string `json:"webhook_secret"`
	}
	// GetEventDeliveries
	GetEventDeliveriesReq {
		BotId     string `path:"bot_id"`
		ConvId    string `form:"conv_id,optional"`
		EventType string `form:"event_type,optional"`
		Status    string `form:"status,optional"`
		Page      int    `form:"page,default=1"`
		Size      int    `form:"size,default=20"`
	}
	EventDeliveryItem {
		EventId     string `json:"event_id"`
		BotId       string `json:"bot_id"`
		ConvId      string `json:"conv_id"`
		EventType   string `json:"event_type"`
		Payload     string `json:"payload"`
		Status      string `json:"status"`
		RetryCount  int32  `json:"retry_count"`
		LastError   string `json:"last_error,omitempty"`
		DeliveredAt int64  `json:"delivered_at,omitempty"`
		CreatedAt   int64  `json:"created_at"`
	}
	GetEventDeliveriesResp {
		List  []EventDeliveryItem `json:"list"`
		Total int64               `json:"total"`
	}
	// RetryEventDelivery
	RetryEventDeliveryReq {
		BotId   string `path:"bot_id"`
		EventId string `path:"event_id"`
	}
	RetryEventDeliveryResp  {}
	// GetConvBots
	GetConvBotsReq {
		ConvId string `path:"conv_id"`
	}
	InstalledBotItem {
		InstId      int64    `json:"inst_id"`
		BotId       string   `json:"bot_id"`
		Name        string   `json:"name"`
		Avatar      string   `json:"avatar"`
		Description string   `json:"description"`
		Permissions []string `json:"permissions"`
		InstalledAt int64    `json:"installed_at"`
	}
	GetConvBotsResp {
		List []InstalledBotItem `json:"list"`
	}
	// InstallBot
	InstallBotReq {
		ConvId      string   `path:"conv_id"`
		BotId       string   `json:"bot_id"`
		Permissions []string `json:"permissions,optional"`
	}
	InstallBotResp  {}
	// BatchInstallBot
	BatchInstallBotReq {
		BotId       string   `json:"bot_id"`
		ConvIds     []string `json:"conv_ids"`
		Permissions []string `json:"permissions,optional"`
	}
	BatchInstallBotResp {
		SuccessCount int32    `json:"success_count"`
		FailedConvs  []string `json:"failed_convs"`
	}
	// UninstallBot
	UninstallBotReq {
		ConvId string `path:"conv_id"`
		BotId  string `json:"bot_id"`
	}
	UninstallBotResp  {}
	// BotGetConv
	BotGetConvReq {
		ConvId string `path:"conv_id"`
	}
	BotGetConvResp {
		ConvId    string `json:"conv_id"`
		Type      string `json:"type"`
		Name      string `json:"name"`
		Avatar    string `json:"avatar"`
		GroupId   int64  `json:"group_id,omitempty"`
		CreatedAt int64  `json:"created_at"`
	}
	// BotGetConvMembers
	BotGetConvMembersReq {
		ConvId string `path:"conv_id"`
	}
	MemberItem {
		Uid    string `json:"uid"`
		Name   string `json:"name"`
		Avatar string `json:"avatar"`
		Role   string `json:"role"`
	}
	BotGetConvMembersResp {
		Members []MemberItem `json:"members"`
	}
	// BotGetMsg
	BotGetMsgReq {
		ConvId string `path:"conv_id"`
		MsgId  string `path:"msg_id"`
	}
	BotMsgItem {
		MsgId        string `json:"msg_id"`
		ConvId       string `json:"conv_id"`
		Sender       string `json:"sender"`
		SenderName   string `json:"sender_name"`
		SenderAvatar string `json:"sender_avatar"`
		Type         string `json:"type"`
		Content      string `json:"content"`
		ContentType  string `json:"content_type"`
		Recalled     bool   `json:"recalled"`
		CreatedAt    int64  `json:"created_at"`
	}
	BotGetMsgResp {
		Msg *BotMsgItem `json:"msg"`
	}
	// BotSendMsg
	BotSendMsgReq {
		ConvId      string `json:"conv_id"`
		Content     string `json:"content"`
		ContentType string `json:"content_type,default=text"`
		Button      string `json:"button,optional"`
	}
	BotSendMsgResp {
		MsgId     string `json:"msg_id"`
		CreatedAt int64  `json:"created_at"`
	}
	// BotRecallMsg
	BotRecallMsgReq {
		ConvId string `path:"conv_id"`
		MsgId  string `path:"msg_id"`
	}
	BotRecallMsgResp  {}
	// BotReplyMsg
	BotReplyMsgReq {
		ConvId      string `json:"conv_id"`
		MsgId       string `json:"msg_id"`
		Content     string `json:"content"`
		ContentType string `json:"content_type,default=text"`
	}
	BotReplyMsgResp {
		MsgId     string `json:"msg_id"`
		CreatedAt int64  `json:"created_at"`
	}
	// BotUploadFile
	BotUploadFileReq  {}
	BotUploadFileResp {
		FileId   string `json:"file_id"`
		FileName string `json:"file_name"`
		FileSize int64  `json:"file_size"`
		Url      string `json:"url"`
		MimeType string `json:"mime_type"`
	}
	// BotGetUser
	BotGetUserReq {
		Uid string `path:"uid"`
	}
	BotGetUserResp {
		Uid    string `json:"uid"`
		Name   string `json:"name"`
		Avatar string `json:"avatar"`
	}
	// BotAuthorize
	BotAuthorizeReq {
		ClientId string `form:"client_id"`
		Scope    string `form:"scope,optional"`
		ConvId   string `form:"conv_id,optional"`
	}
	BotAuthorizeResp {
		Bot            *BotItem `json:"bot"`
		RequestedScope []string `json:"requested_scope"`
		ConvId         string   `json:"conv_id"`
	}
	// ApproveAuthorize
	ApproveAuthorizeReq {
		ClientId    string `json:"client_id"`
		RedirectUri string `json:"redirect_uri"`
		Scope       string `json:"scope"`
		ConvId      string `json:"conv_id"`
		State       string `json:"state,optional"`
	}
	ApproveAuthorizeResp {
		RedirectUrl string `json:"redirect_url"`
	}
	// BotToken
	BotTokenReq {
		GrantType    string `form:"grant_type"`
		ClientId     string `form:"client_id"`
		ClientSecret string `form:"client_secret"`
		Code         string `form:"code,optional"`
		RedirectUri  string `form:"redirect_uri,optional"`
		RefreshToken string `form:"refresh_token,optional"`
	}
	BotTokenResp {
		AccessToken  string `json:"access_token"`
		TokenType    string `json:"token_type"`
		Scope        string `json:"scope"`
		ExpiresIn    int64  `json:"expires_in"`
		RefreshToken string `json:"refresh_token"`
		BotId        string `json:"bot_id"`
	}
)

// Bot服务 - Developer APIs
@server (
	prefix:     /api/v1/bot/developer
	group:      bot
	middleware: AuthMiddleware
)
service gateway-api {
	@handler CreateBot
	post /bots (CreateBotReq) returns (CreateBotResp)

	@handler ListMyBots
	get /bots (ListMyBotsReq) returns (ListMyBotsResp)

	@handler GetBot
	get /bots/:bot_id (GetBotReq) returns (GetBotResp)

	@handler UpdateBot
	put /bots/:bot_id (UpdateBotReq) returns (UpdateBotResp)

	@handler DeleteBot
	delete /bots/:bot_id (DeleteBotReq) returns (DeleteBotResp)

	@handler GetBotInstallations
	get /bots/:bot_id/installations (GetBotInstallationsReq) returns (GetBotInstallationsResp)

	@handler GetBotRateLimit
	get /bots/:bot_id/rate-limit (GetBotRateLimitReq) returns (GetBotRateLimitResp)

	@handler UpdateBotRateLimit
	put /bots/:bot_id/rate-limit (UpdateBotRateLimitReq) returns (UpdateBotRateLimitResp)

	@handler RegenerateCredential
	post /bots/:bot_id/credentials/regenerate (RegenerateCredentialReq) returns (RegenerateCredentialResp)

	@handler RotateWebhookSecret
	post /bots/:bot_id/webhook-secret/rotate (RotateWebhookSecretReq) returns (RotateWebhookSecretResp)

	@handler GetEventDeliveries
	get /bots/:bot_id/event-deliveries (GetEventDeliveriesReq) returns (GetEventDeliveriesResp)

	@handler RetryEventDelivery
	post /bots/:bot_id/event-deliveries/:event_id/retry (RetryEventDeliveryReq) returns (RetryEventDeliveryResp)
}

// Bot服务 - Community APIs (官方Bot + 搜索)
@server (
	prefix:     /api/v1/bot/community
	group:      bot
	middleware: AuthMiddleware
)
service gateway-api {
	@handler ListCommunityBots
	get /bots (ListCommunityBotsReq) returns (ListCommunityBotsResp)
}

// Bot服务 - Installation APIs
@server (
	prefix:     /api/v1/bot/installation
	group:      bot
	middleware: AuthMiddleware
)
service gateway-api {
	@handler GetConvBots
	get /convs/:conv_id/bots (GetConvBotsReq) returns (GetConvBotsResp)

	@handler InstallBot
	post /convs/:conv_id/bots/install (InstallBotReq) returns (InstallBotResp)

	@handler BatchInstallBot
	post /bots/install (BatchInstallBotReq) returns (BatchInstallBotResp)

	@handler UninstallBot
	post /convs/:conv_id/bots/uninstall (UninstallBotReq) returns (UninstallBotResp)
}

// Bot服务 - Bot APIs (Bot调用接口)
@server (
	prefix:     /api/v1/bot
	group:      bot
	middleware: AuthMiddleware
)
service gateway-api {
	@handler BotGetConv
	get /convs/:conv_id (BotGetConvReq) returns (BotGetConvResp)

	@handler BotGetConvMembers
	get /convs/:conv_id/members (BotGetConvMembersReq) returns (BotGetConvMembersResp)

	@handler BotGetMsg
	get /convs/:conv_id/msgs/:msg_id (BotGetMsgReq) returns (BotGetMsgResp)

	@handler BotSendMsg
	post /convs/:conv_id/msgs (BotSendMsgReq) returns (BotSendMsgResp)

	@handler BotRecallMsg
	post /convs/:conv_id/msgs/:msg_id/recall (BotRecallMsgReq) returns (BotRecallMsgResp)

	@handler BotReplyMsg
	post /convs/:conv_id/msgs/reply (BotReplyMsgReq) returns (BotReplyMsgResp)

	@handler BotUploadFile
	post /files (BotUploadFileReq) returns (BotUploadFileResp)

	@handler BotGetUser
	get /users/:uid (BotGetUserReq) returns (BotGetUserResp)
}

// Bot服务 - OAuth2 APIs（公开接口：授权页查询、Token 签发，使用 client_id/secret 认证）
@server (
	prefix: /api/v1/bot/oauth2
	group:  bot
)
service gateway-api {
	@handler BotAuthorize
	get /authorize (BotAuthorizeReq) returns (BotAuthorizeResp)

	@handler BotToken
	post /token (BotTokenReq) returns (BotTokenResp)
}

// Bot服务 - OAuth2 APIs（需用户认证：确认授权）
@server (
	prefix:     /api/v1/bot/oauth2
	group:      bot
	middleware: AuthMiddleware
)
service gateway-api {
	@handler ApproveAuthorize
	post /authorize (ApproveAuthorizeReq) returns (ApproveAuthorizeResp)
}

// Bot交互 - AI 功能接口
type (
	BotSummarizeReq {
		ConvID     string `json:"conv_id"`
		SinceMsgId int64  `json:"since_msg_id,optional"`
	}
	BotSummarizeResp {
		Summary     string   `json:"summary"`
		KeyPoints   []string `json:"key_points"`
		ActionItems []string `json:"action_items"`
	}
	SummarizeTicket {
		Ticket string `json:"ticket"`
	}
	SummarizeResultReq {
		Ticket string `form:"ticket"`
	}
	SummarizeResultResp {
		Status string            `json:"status"`
		Result *BotSummarizeResp `json:"result,optional"`
		Error  string            `json:"error,optional"`
	}
	BotTranslateReq {
		Text       string `json:"text"`
		TargetLang string `json:"target_lang,optional"`
		SourceLang string `json:"source_lang,optional"`
	}
	BotTranslateResp {
		Text       string `json:"text"`
		SourceLang string `json:"source_lang"`
		TargetLang string `json:"target_lang"`
	}
	BotSuggestReq {
		ConvID string `json:"conv_id"`
	}
	BotSuggestResp {
		Suggestions []string `json:"suggestions"`
	}
	BotModerateReq {
		Text string `json:"text"`
	}
	BotModerateResp {
		Safe   bool   `json:"safe"`
		Reason string `json:"reason"`
	}
)

@server (
	prefix:     /api/v1
	group:      bot_interact
	middleware: AuthMiddleware
)
service gateway-api {
	@handler BotSummarize
	post /bot/summarize (BotSummarizeReq) returns (SummarizeTicket)

	@handler BotSummarizeResult
	get /bot/summarize/result (SummarizeResultReq) returns (SummarizeResultResp)

	@handler BotTranslate
	post /bot/translate (BotTranslateReq) returns (BotTranslateResp)

	@handler BotSuggest
	post /bot/suggest (BotSuggestReq) returns (BotSuggestResp)

	@handler BotModerate
	post /bot/moderate (BotModerateReq) returns (BotModerateResp)
}

// RAG 知识库服务 Model
type (
	// 知识库
	CreateKBRequest {
		Name         string `json:"name"`
		Description  string `json:"description,optional"`
		SourceType   string `json:"source_type,optional"`
		SourceConfig string `json:"source_config,optional"`
	}
	CreateKBResponse {
		KbID string `json:"kb_id"`
	}
	ListKBsRequest {
		Page int `form:"page,default=1"`
		Size int `form:"size,default=20"`
	}
	KBItem {
		KbID        string `json:"kb_id"`
		Name        string `json:"name"`
		Description string `json:"description"`
		Status      string `json:"status"`
		DocCount    int64  `json:"doc_count"`
		ChunkCount  int64  `json:"chunk_count"`
		TotalSize   int64  `json:"total_size"`
		CreatedAt   int64  `json:"created_at"`
		UpdatedAt   int64  `json:"updated_at"`
	}
	ListKBsResponse {
		List  []KBItem `json:"list"`
		Total int64    `json:"total"`
	}
	GetKBRequest {
		KbID string `path:"kb_id"`
	}
	GetKBResponse {
		KB KBItem `json:"kb"`
	}
	UpdateKBRequest {
		KbID        string `path:"kb_id"`
		Name        string `json:"name,optional"`
		Description string `json:"description,optional"`
	}
	DeleteKBRequest {
		KbID string `path:"kb_id"`
	}
	// 文档
	ListDocsRequest {
		KbID string `path:"kb_id"`
		Page int    `form:"page,default=1"`
		Size int    `form:"size,default=20"`
	}
	DocItem {
		DocID       string `json:"doc_id"`
		KbID        string `json:"kb_id"`
		FileName    string `json:"file_name"`
		ContentType string `json:"content_type"`
		FileSize    int64  `json:"file_size"`
		Status      string `json:"status"`
		ChunkCount  int64  `json:"chunk_count"`
		ErrorMsg    string `json:"error_msg,omitempty"`
		CreatedAt   int64  `json:"created_at"`
		UpdatedAt   int64  `json:"updated_at"`
	}
	ListDocsResponse {
		List  []DocItem `json:"list"`
		Total int64     `json:"total"`
	}
	GetDocStatusRequest {
		KbID  string `path:"kb_id"`
		DocID string `path:"doc_id"`
	}
	GetDocStatusResponse {
		Doc DocItem `json:"doc"`
	}
	DeleteDocRequest {
		KbID  string `path:"kb_id"`
		DocID string `path:"doc_id"`
	}
	GetDocChunksRequest {
		KbID  string `path:"kb_id"`
		DocID string `path:"doc_id"`
		Page  int    `form:"page,default=1"`
		Size  int    `form:"size,default=50"`
	}
	ChunkItem {
		ChunkID    string   `json:"chunk_id"`
		Content    string   `json:"content"`
		ChunkIndex int32    `json:"chunk_index"`
		TokenCount int64    `json:"token_count"`
		Entities   []string `json:"entities"`
	}
	GetDocChunksResponse {
		List  []ChunkItem `json:"list"`
		Total int64       `json:"total"`
	}
	// 上传文档请求（先上传到 OSS，再提交索引）
	UploadDocRequest {
		KbID        string `path:"kb_id"`
		OssKey      string `json:"oss_key"`               // OSS 对象 key
		FileName    string `json:"file_name,optional"`    // 原始文件名
		ContentType string `json:"content_type,optional"` // MIME 类型
		FileSize    int64  `json:"file_size,optional"`
	}
	UploadDocResponse {
		DocID  string `json:"doc_id"`
		Status string `json:"status"`
	}
	// 知识库授权（Bot 维度）
	GrantBotKBAccessRequest {
		BotID  int64 `json:"bot_id"`
		ConvID int64 `json:"conv_id"`
	}
	RevokeBotKBAccessRequest {
		BotID  int64 `json:"bot_id"`
		ConvID int64 `json:"conv_id"`
	}
	// 知识库授权（知识库维度）
	AuthorizeKBRequest {
		KbID       string `json:"kb_id"`
		BotID      int64  `json:"bot_id"`
		ConvID     int64  `json:"conv_id"`
		Permission string `json:"permission,default=READ"`
	}
	RevokeKBAuthRequest {
		KbID   string `json:"kb_id"`
		BotID  int64  `json:"bot_id"`
		ConvID int64  `json:"conv_id"`
	}
	ListKBAuthsRequest {
		KbID  string `form:"kb_id,optional"`
		BotID int64  `form:"bot_id,optional"`
	}
	KBAuthItem {
		KbID       string `json:"kb_id"`
		KbName     string `json:"kb_name"`
		BotID      int64  `json:"bot_id"`
		ConvID     int64  `json:"conv_id"`
		Permission string `json:"permission"`
		GrantedAt  int64  `json:"granted_at"`
	}
	ListKBAuthsResponse {
		List []KBAuthItem `json:"list"`
	}
	// Bot 可访问的知识库列表
	ListBotKBsRequest {
		BotID  int64 `form:"bot_id"`
		ConvID int64 `form:"conv_id"`
	}
	// 知识检索
	SearchKnowledgeRequest {
		KbID           string  `json:"kb_id"`
		Query          string  `json:"query"`
		TopK           int32   `json:"top_k,default=10"`
		VectorWeight   float64 `json:"vector_weight,optional"`
		GraphWeight    float64 `json:"graph_weight,optional"`
		KeywordWeight  float64 `json:"keyword_weight,optional"`
		RerankStrategy string  `json:"rerank_strategy,optional"`
	}
	RecallItemInfo {
		ChunkID      string   `json:"chunk_id"`
		DocID        string   `json:"doc_id"`
		DocName      string   `json:"doc_name"`
		Content      string   `json:"content"`
		VectorScore  float64  `json:"vector_score"`
		GraphScore   float64  `json:"graph_score"`
		KeywordScore float64  `json:"keyword_score"`
		FusionScore  float64  `json:"fusion_score"`
		Entities     []string `json:"entities"`
		Relations    []string `json:"relations"`
		ChunkIndex   int32    `json:"chunk_index"`
	}
	MetaCogInfo {
		OverallConfidence float64        `json:"overall_confidence"`
		CoverageScore     float64        `json:"coverage_score"`
		RelevanceScore    float64        `json:"relevance_score"`
		ConsistencyScore  float64        `json:"consistency_score"`
		FreshnessScore    float64        `json:"freshness_score"`
		Warnings          []string       `json:"warnings"`
		Citations         []CitationItem `json:"citations"`
	}
	CitationItem {
		DocName      string  `json:"doc_name"`
		ChunkID      string  `json:"chunk_id"`
		ChunkIndex   int32   `json:"chunk_index"`
		Contribution float64 `json:"contribution"`
		Excerpt      string  `json:"excerpt"`
	}
	SearchKnowledgeResponse {
		Items     []RecallItemInfo `json:"items"`
		Total     int64            `json:"total"`
		LatencyMs int64            `json:"latency_ms"`
		Metacog   *MetaCogInfo     `json:"metacog,omitempty"`
	}
	// 跨知识库检索
	CrossKBSearchRequest {
		KbIDs         []string `json:"kb_ids"`
		Query         string   `json:"query"`
		TopK          int32    `json:"top_k,default=10"`
		VectorWeight  float64  `json:"vector_weight,optional"`
		GraphWeight   float64  `json:"graph_weight,optional"`
		KeywordWeight float64  `json:"keyword_weight,optional"`
	}
	CrossKBSearchResponse {
		Items     []RecallItemInfo `json:"items"`
		KbCounts  map[string]int64 `json:"kb_counts"`
		LatencyMs int64            `json:"latency_ms"`
		Metacog   *MetaCogInfo     `json:"metacog,omitempty"`
	}
	// 元认知评估
	AssessRetrievalRequest {
		Query   string           `json:"query"`
		Results []RecallItemInfo `json:"results"`
	}
	AssessRetrievalResponse {
		Score MetaCogInfo `json:"score"`
	}
	// 知识库健康分析
	AnalyzeKBHealthRequest {
		KbID string `path:"kb_id"`
	}
	KBHealthInfo {
		KbID           string            `json:"kb_id"`
		TotalDocs      int64             `json:"total_docs"`
		TotalChunks    int64             `json:"total_chunks"`
		TotalEntities  int64             `json:"total_entities"`
		TotalRelations int64             `json:"total_relations"`
		AvgChunkSize   float64           `json:"avg_chunk_size"`
		CoverageRate   float64           `json:"coverage_rate"`
		ConflictRate   float64           `json:"conflict_rate"`
		HealthStatus   string            `json:"health_status"`
		LastUpdatedAt  int64             `json:"last_updated_at"`
		Conflicts      []ConflictInfo    `json:"conflicts"`
		Gaps           []CoverageGapInfo `json:"gaps"`
	}
	ConflictInfo {
		Entity            string   `json:"entity"`
		ConflictingChunks []string `json:"conflicting_chunks"`
		Description       string   `json:"description"`
	}
	CoverageGapInfo {
		Topic      string `json:"topic"`
		Suggestion string `json:"suggestion"`
	}
	AnalyzeKBHealthResponse {
		Report KBHealthInfo `json:"report"`
	}
	// 图谱
	GetSubGraphRequest {
		KbID     string `form:"kb_id"`
		EntityID string `form:"entity_id"`
		Depth    int32  `form:"depth,default=2"`
		Limit    int32  `form:"limit,default=50"`
	}
	GraphEntityInfo {
		EntityID   string            `json:"entity_id"`
		Name       string            `json:"name"`
		Type       string            `json:"type"`
		Properties map[string]string `json:"properties"`
	}
	GraphRelationInfo {
		RelationID   string `json:"relation_id"`
		SourceEntity string `json:"source_entity"`
		TargetEntity string `json:"target_entity"`
		RelationType string `json:"relation_type"`
		ChunkID      string `json:"chunk_id"`
	}
	GetSubGraphResponse {
		Entities  []GraphEntityInfo   `json:"entities"`
		Relations []GraphRelationInfo `json:"relations"`
	}
)

// RAG 知识库服务
@server (
	prefix:     /api/v1/rag
	group:      rag
	middleware: AuthMiddleware
)
service gateway-api {
	// 知识库管理
	@handler CreateKnowledgeBase
	post /kb/create (CreateKBRequest) returns (CreateKBResponse)

	@handler ListKnowledgeBases
	get /kb/list (ListKBsRequest) returns (ListKBsResponse)

	@handler GetKnowledgeBase
	get /kb/:kb_id (GetKBRequest) returns (GetKBResponse)

	@handler UpdateKnowledgeBase
	post /kb/:kb_id/update (UpdateKBRequest) returns (EmptyReponse)

	@handler DeleteKnowledgeBase
	post /kb/:kb_id/delete (DeleteKBRequest) returns (EmptyReponse)

	// 文档管理
	@handler UploadDocument
	post /kb/:kb_id/doc/upload (UploadDocRequest) returns (UploadDocResponse)

	@handler ListDocuments
	get /kb/:kb_id/doc/list (ListDocsRequest) returns (ListDocsResponse)

	@handler GetDocumentStatus
	get /kb/:kb_id/doc/:doc_id (GetDocStatusRequest) returns (GetDocStatusResponse)

	@handler DeleteDocument
	post /kb/:kb_id/doc/:doc_id/delete (DeleteDocRequest) returns (EmptyReponse)

	@handler GetDocumentChunks
	get /kb/:kb_id/doc/:doc_id/chunks (GetDocChunksRequest) returns (GetDocChunksResponse)

	// 知识库授权
	@handler GrantBotKBAccess
	post /auth/grant-bot (GrantBotKBAccessRequest) returns (EmptyReponse)

	@handler RevokeBotKBAccess
	post /auth/revoke-bot (RevokeBotKBAccessRequest) returns (EmptyReponse)

	@handler AuthorizeKB
	post /auth/authorize-kb (AuthorizeKBRequest) returns (EmptyReponse)

	@handler RevokeKBAuth
	post /auth/revoke-kb (RevokeKBAuthRequest) returns (EmptyReponse)

	@handler ListKBAuthorizations
	get /auth/list (ListKBAuthsRequest) returns (ListKBAuthsResponse)

	@handler ListBotKnowledgeBases
	get /auth/bot-kbs (ListBotKBsRequest) returns (ListKBsResponse)

	// 知识检索
	@handler SearchKnowledge
	post /search (SearchKnowledgeRequest) returns (SearchKnowledgeResponse)

	@handler CrossKBSearch
	post /search/cross (CrossKBSearchRequest) returns (CrossKBSearchResponse)

	// 元认知
	@handler AssessRetrieval
	post /metacog/assess (AssessRetrievalRequest) returns (AssessRetrievalResponse)

	@handler AnalyzeKBHealth
	get /kb/:kb_id/health (AnalyzeKBHealthRequest) returns (AnalyzeKBHealthResponse)

	// 图谱
	@handler GetSubGraph
	get /graph/sub (GetSubGraphRequest) returns (GetSubGraphResponse)

	// 外部知识库同步
	@handler TriggerExternalSync
	post /kb/:kb_id/sync/trigger (TriggerExternalSyncRequest) returns (TriggerExternalSyncResponse)

	@handler GetSyncStatus
	get /kb/:kb_id/sync/:sync_id (GetSyncStatusRequest) returns (GetSyncStatusResponse)

	@handler ListExternalSyncs
	get /kb/:kb_id/sync/list (ListExternalSyncsRequest) returns (ListExternalSyncsResponse)
}

// 外部知识库同步 Model
type (
	TriggerExternalSyncRequest {
		KbID string `path:"kb_id"`
	}
	TriggerExternalSyncResponse {
		SyncID string `json:"sync_id"`
		Status string `json:"status"`
	}
	GetSyncStatusRequest {
		KbID   string `path:"kb_id"`
		SyncID string `path:"sync_id"`
	}
	GetSyncStatusResponse {
		Sync ExternalSyncInfo `json:"sync"`
	}
	ListExternalSyncsRequest {
		KbID string `path:"kb_id"`
	}
	ListExternalSyncsResponse {
		List []ExternalSyncInfo `json:"list"`
	}
	ExternalSyncInfo {
		SyncID       string `json:"sync_id"`
		KbID         string `json:"kb_id"`
		SourceType   string `json:"source_type"`
		SourceConfig string `json:"source_config"`
		SyncStatus   string `json:"sync_status"`
		SyncError    string `json:"sync_error,omitempty"`
		LastSyncedAt int64  `json:"last_synced_at"`
		CreatedAt    int64  `json:"created_at"`
	}
)

